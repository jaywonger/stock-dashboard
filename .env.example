# Stock Data Providers
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# News Sources
NEWSAPI_KEY=
BENZINGA_API_KEY=
RSS_FEED_URLS=https://feeds.reuters.com/reuters/businessNews,https://feeds.content.dowjones.io/public/rss/mw_realtimeheadlines,https://feeds.a.dj.com/rss/RSSMarketsMain.xml,https://feeds.bloomberg.com/markets/news.rss,https://www.ft.com/world?format=rss
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stocks-dashboard/0.1 by local-dev
REDDIT_SUBREDDITS=wallstreetbets,investing

# Macro Data (Federal Reserve Economic Data)
FRED_API_KEY=

# Optional AI Commentary
# Set LLM_PROVIDER to: auto | openai | gemini | anthropic | ollama | none
LLM_PROVIDER=auto

# OpenAI-compatible providers (OpenAI / DeepSeek / Qwen / etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=qwen3.5-plus

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Ollama
OLLAMA_API_BASE=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b
ANALYSIS_CACHE_TTL_MS=300000
ANALYSIS_OHLCV_TTL_MS=300000

# App Config
API_PORT=3001
PORT=3001
CACHE_TTL_SECONDS=300
PROVIDER_TIMEOUT_MS=10000
PROVIDER_HTTP_TIMEOUT_MS=12000
NEWS_BOOTSTRAP_TIMEOUT_MS=8000

# Debug
DB_SQLITE_FALLBACK_TRACE=0
