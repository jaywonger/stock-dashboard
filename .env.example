# Stock Data Providers
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# News Sources
NEWSAPI_KEY=
BENZINGA_API_KEY=
FRED_API_KEY=
# Reddit API (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stocks-dashboard/0.1 by local-dev
REDDIT_SUBREDDITS=wallstreetbets,investing
# Add custom RSS feed URLs as comma-separated list:
RSS_FEED_URLS=https://feeds.reuters.com/reuters/businessNews,https://feeds.content.dowjones.io/public/rss/mw_realtimeheadlines

# App Config
PORT=3000
CACHE_TTL_SECONDS=300

# AI Agent Configuration (LiteLLM)
# Priority: LITELLM_MODEL > OPENAI_MODEL > GEMINI_MODEL > CLAUDE_MODEL
# See: https://docs.litellm.ai/docs/providers

# Option 1: Use LiteLLM unified interface (recommended - supports 100+ models)
LITELLM_MODEL=gemini/gemini-2.0-flash
LITELLM_API_KEY=

# Option 2: Direct provider keys (fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-latest
OLLAMA_API_BASE=
OLLAMA_MODEL=llama3.1:8b
LLM_PROVIDER=auto

# Agent Settings
AGENT_ENABLED=false
ANALYSIS_DELAY_SECONDS=2
